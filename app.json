{
  "expo": {
    "name": "Workout Table",
    "slug": "workout-table",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.jpg",
    "scheme": "workouttable",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.myworkout.table",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.jpg",
        "backgroundColor": "#2E346E"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2E346E",
          "image": "./assets/icon.jpg",
          "imageWidth": 200
        }
      ],
      "expo-image",
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "1d0492e6-e68f-43f7-b3b5-36bb574e6df3"
      }
    }
  }
}
